    "difficulty": "hard",
    "freeSelect": true,
    "viewBox": [
      296,
      282
    ],
    "prompt": "Each dot is a risk on the probability/impact matrix. Tap every risk in the red zone (probability × impact ≥ 12) — those breach the threshold and must be escalated with a response plan.",
    "caption": "Rows = probability, columns = impact (1–5).",
    "vars": {
      "cells": {
        "sampleInt": [
          0,
          24
        ],
        "count": 4,
        "unique": true
      },
      "k6": {
        "range": 6
      },
      "k5": {
        "range": 5
      }
    },
    "guard": "count([(floor(cells[0]/5)+1)*(cells[0]%5+1)>=12, (floor(cells[1]/5)+1)*(cells[1]%5+1)>=12, (floor(cells[2]/5)+1)*(cells[2]%5+1)>=12, (floor(cells[3]/5)+1)*(cells[3]%5+1)>=12]) >= 1 && count([(floor(cells[0]/5)+1)*(cells[0]%5+1)>=12, (floor(cells[1]/5)+1)*(cells[1]%5+1)>=12, (floor(cells[2]/5)+1)*(cells[2]%5+1)>=12, (floor(cells[3]/5)+1)*(cells[3]%5+1)>=12]) <= 3",
    "derived": {
      "P": "[floor(cells[0]/5)+1,floor(cells[1]/5)+1,floor(cells[2]/5)+1,floor(cells[3]/5)+1]",
      "Imp": "[cells[0]%5+1,cells[1]%5+1,cells[2]%5+1,cells[3]%5+1]",
      "prod": "[P[0]*Imp[0],P[1]*Imp[1],P[2]*Imp[2],P[3]*Imp[3]]",
      "nRed": "count([prod[0]>=12,prod[1]>=12,prod[2]>=12,prod[3]>=12])",
      "risks": "[[P[0],Imp[0]],[P[1],Imp[1]],[P[2],Imp[2]],[P[3],Imp[3]]]"
    },
    "draw": [
      {
        "op": "repeat",
        "over": "k6",
        "as": "k",
        "do": [
          {
            "op": "line",
            "x1": "56 + k*44",
            "y1": 28,
            "x2": "56 + k*44",
            "y2": 248,
            "width": 0.5
          },
          {
            "op": "line",
            "x1": 56,
            "y1": "28 + k*44",
            "x2": 276,
            "y2": "28 + k*44",
            "width": 0.5
          }
        ]
      },
      {
        "op": "repeat",
        "over": "k5",
        "as": "c",
        "do": [
          {
            "op": "text",
            "x": "78 + c*44",
            "y": 262,
            "text": "c+1",
            "size": 8,
            "anchor": "middle"
          },
          {
            "op": "text",
            "x": 46,
            "y": "28 + (4-c)*44 + 25",
            "text": "c+1",
            "size": 8,
            "anchor": "end"
          }
        ]
      },
      {
        "op": "text",
        "x": 166,
        "y": 276,
        "text": "'Impact →'",
        "size": 8.5,
        "anchor": "middle"
      },
      {
        "op": "text",
        "x": 56,
        "y": 20,
        "text": "'Probability ↑'",
        "size": 8.5,
        "anchor": "start"
      },
      {
        "op": "repeat",
        "over": "risks",
        "as": "b",
        "do": [
          {
            "op": "circle",
            "cx": "56 + (b[1]-1)*44 + 22",
            "cy": "28 + (5-b[0])*44 + 22",
            "r": 10,
            "color": "ink",
            "width": 1.4
          },
          {
            "op": "text",
            "x": "56 + (b[1]-1)*44 + 22",
            "y": "28 + (5-b[0])*44 + 22 + 3.2",
            "text": "'R' + (i+1)",
            "size": 9,
            "anchor": "middle"
          }
        ]
      }
    ],
    "regions": {
      "repeat": "risks",
      "as": "b",
      "items": [
        {
          "id": "'r' + i",
          "x": "56 + (b[1]-1)*44",
          "y": "28 + (5-b[0])*44",
          "w": 44,
          "h": 44,
          "correct": "b[0]*b[1] >= 12",
          "label": "'R' + (i+1)",
          "why": "(b[0]*b[1]) >= 12 ? ('P×I = ' + (b[0]*b[1]) + ' ≥ 12 — red zone, escalate.') : ('P×I = ' + (b[0]*b[1]) + ' — below the threshold, monitor.')"
        }
      ]
    },
    "explanation": "{{nRed}} risk(s) score probability × impact ≥ 12 (the red zone) — escalate those with a response plan and contingency reserve; the rest you monitor."
  },
