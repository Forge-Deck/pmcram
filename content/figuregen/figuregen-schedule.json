      { "op": "arrow", "x1": 136, "y1": 163, "x2": 170, "y2": 163, "width": 1.4, "head": 8 },
      { "op": "line", "x1": 228, "y1": 63, "x2": 280, "y2": 104, "width": 1.3 },
      { "op": "line", "x1": 228, "y1": 163, "x2": 280, "y2": 116, "width": 1.3 },

      { "op": "rect", "x": 78, "y": 40, "w": 58, "h": 46, "rx": 4, "width": 1.4 },
      { "op": "text", "x": 107, "y": 54, "text": "0 + ' | ' + efA", "size": 9, "anchor": "middle" },
      { "op": "text", "x": 107, "y": 68, "text": "'A ' + dA", "size": 11, "anchor": "middle" },
      { "op": "text", "x": 107, "y": 80, "text": "lsA + ' | ' + (lsA + dA)", "size": 9, "anchor": "middle" },

      { "op": "rect", "x": 170, "y": 40, "w": 58, "h": 46, "rx": 4, "width": 1.4 },
      { "op": "text", "x": 199, "y": 54, "text": "efA + ' | ' + efB", "size": 9, "anchor": "middle" },
      { "op": "text", "x": 199, "y": 68, "text": "'B ' + dB", "size": 11, "anchor": "middle" },
      { "op": "text", "x": 199, "y": 80, "text": "lsB + ' | ' + (lsB + dB)", "size": 9, "anchor": "middle" },

      { "op": "rect", "x": 78, "y": 140, "w": 58, "h": 46, "rx": 4, "width": 1.4 },
      { "op": "text", "x": 107, "y": 154, "text": "0 + ' | ' + efC", "size": 9, "anchor": "middle" },
      { "op": "text", "x": 107, "y": 168, "text": "'C ' + dC", "size": 11, "anchor": "middle" },
      { "op": "text", "x": 107, "y": 180, "text": "lsC + ' | ' + (lsC + dC)", "size": 9, "anchor": "middle" },

      { "op": "rect", "x": 170, "y": 140, "w": 58, "h": 46, "rx": 4, "width": 1.4 },
      { "op": "text", "x": 199, "y": 154, "text": "efC + ' | ' + efD", "size": 9, "anchor": "middle" },
