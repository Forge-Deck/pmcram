      { "op": "text", "x": 199, "y": 180, "text": "lsD + ' | ' + (lsD + dD)", "size": 9, "anchor": "middle" },

      { "op": "text", "x": 160, "y": 212, "text": "'ES | EF on top  ·  LS | LF below'", "size": 9, "anchor": "middle" }
    ],
    "regions": [
      {
        "id": "'A'",
        "x": 78,
        "y": 40,
        "w": 58,
        "h": 46,
        "correct": "floatTop > 0",
        "label": "'A'",
        "why": "floatTop > 0 ? ('Float ' + (lsA - 0) + ' (LS ' + lsA + ' ≠ ES 0) — off the critical path.') : 'Zero float — on the critical path.'"
      },
      {
        "id": "'B'",
        "x": 170,
        "y": 40,
        "w": 58,
        "h": 46,
        "correct": "floatTop > 0",
        "label": "'B'",
        "why": "floatTop > 0 ? ('Float ' + (lsB - efA) + ' (LS ' + lsB + ' ≠ ES ' + efA + ') — off the critical path.') : 'Zero float — on the critical path.'"
      },
      {
