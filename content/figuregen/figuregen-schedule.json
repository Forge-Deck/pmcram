  {
    "schema": "figuregen/v1",
    "id": "critical-path",
    "kind": "hotspot",
    "domain": "Process",
    "topic": "Schedule",
    "difficulty": "medium",
    "viewBox": [320, 220],
    "prompt": "Total float = LS − ES. Tap EVERY activity that is not on the critical path (i.e. has float).",
    "caption": "Two parallel paths from Start to End. Each box: ES|EF (top), LS|LF (bottom).",
    "vars": {
      "dA": { "int": [2, 9] },
      "dB": { "int": [2, 9] },
      "dC": { "int": [2, 9] },
      "dD": { "int": [2, 9] }
    },
    "guard": "dA + dB != dC + dD",
    "derived": {
      "p1": "dA + dB",
      "p2": "dC + dD",
      "T": "max(p1, p2)",
      "efA": "dA",
      "efB": "dA + dB",
      "efC": "dC",
      "efD": "dC + dD",
      "lsB": "T - dB",
      "lsA": "lsB - dA",
      "lsD": "T - dD",
      "lsC": "lsD - dC",
      "floatTop": "T - p1",
      "floatBot": "T - p2",
      "longer": "p1 > p2 ? 'A→B' : 'C→D'",
      "shorter": "p1 > p2 ? 'C→D' : 'A→B'",
      "slack": "T - min(p1, p2)"
    },
    "draw": [
