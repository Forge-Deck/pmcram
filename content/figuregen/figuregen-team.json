[
  {
    "schema": "figuregen/v1",
    "id": "tuckman",
    "kind": "choice",
    "domain": "People",
    "topic": "Team development",
    "difficulty": "easy",
    "viewBox": [320, 192],
    "prompt": "{{qtext[qi]}}",
    "caption": "Tuckman performance curve across the stages.",
    "vars": { "qi": { "int": [0, 3] } },
    "derived": {
      "qtext": "['Which stage is marked by conflict as members challenge each other and negotiate roles?','At which stage does the team reach its peak performance?','Which stage centres on wrapping up the work and releasing the team?','At which stage do norms, trust and shared working agreements settle in?']",
      "aIdx": "[1,3,4,2]",
      "whys": "['Storming is the conflict stage; performance often dips here.','Performing is where the team works effectively with little friction.','Adjourning (mourning) is the closure / release stage.','Norming is where the team agrees how it will work together.']",
      "ans": "aIdx[qi]",
      "stages": "[['Forming',58,99],['Storming',115,140],['Norming',172,86],['Performing',229,38],['Adjourning',286,110]]"
    },
    "draw": [
      { "op": "line", "x1": 44, "y1": 168, "x2": 300, "y2": 168, "width": 1.3 },
      { "op": "line", "x1": 44, "y1": 30, "x2": 44, "y2": 168, "width": 1.3 },
      { "op": "text", "x": 36, "y": 34, "text": "'perf.'", "size": 7, "anchor": "end" },
      { "op": "polyline", "points": [58, 99, 115, 140, 172, 86, 229, 38, 286, 110], "width": 2 },
      {
        "op": "repeat",
        "over": "stages",
        "as": "st",
        "do": [
          { "op": "circle", "cx": "st[1]", "cy": "st[2]", "r": 3, "fill": "ink" },
          { "op": "text", "x": "st[1]", "y": 182, "text": "st[0]", "size": 7, "anchor": "middle" }
        ]
      }
    ],
    "choices": {
      "repeat": "stages",
      "as": "st",
      "items": [
        { "text": "st[0]", "correct": "i == ans", "why": "i == ans ? whys[qi] : ''" }
      ]
    },
    "explanation": "Tuckman's stages run Forming → Storming → Norming → Performing → Adjourning. {{whys[qi]}}"
  },
