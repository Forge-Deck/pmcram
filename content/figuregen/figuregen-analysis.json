[
  {
    "schema": "figuregen/v1",
    "id": "tornado",
    "kind": "choice",
    "domain": "Business Environment",
    "topic": "Sensitivity analysis",
    "difficulty": "medium",
    "viewBox": [350, 200],
    "prompt": "What does this tornado (sensitivity) diagram tell you?",
    "caption": "Bars sorted widest-first around the baseline.",
    "vars": {
      "names": { "sample": ["Material price", "Labour rate", "Scope volatility", "FX rate", "Productivity", "Vendor lead time", "Interest rate"], "count": 4 },
      "w0": { "int": [150, 190] },
      "w1": { "int": [110, 145] },
      "w2": { "int": [70, 105] },
      "w3": { "int": [36, 64] }
    },
    "derived": {
      "widths": "sortdesc([w0, w1, w2, w3])",
      "top": "names[0]",
      "bottom": "names[3]"
    },
    "draw": [
      { "op": "line", "x1": 175, "y1": 22, "x2": 175, "y2": 178, "width": 1, "dash": "3 3" },
      { "op": "text", "x": 175, "y": 16, "text": "'baseline'", "size": 8, "anchor": "middle" },
      {
        "op": "repeat",
        "over": "names",
        "as": "nm",
        "do": [
          { "op": "rect", "x": "175 - widths[i]/2", "y": "34 + i*38", "w": "widths[i]", "h": 26, "rx": 3, "fill": "ink", "fillOpacity": 0.1, "width": 1.2 },
          { "op": "text", "x": 175, "y": "34 + i*38 + 17", "text": "nm", "size": 8.5, "anchor": "middle" }
        ]
      }
    ],
    "choices": [
      { "id": "c1", "text": "'The outcome is most sensitive to ' + top + '.'", "correct": "true", "why": "top + ' has the widest bar — the biggest swing in the outcome.'" },
      { "id": "c2", "text": "'The outcome is most sensitive to ' + bottom + '.'", "correct": "false", "why": "bottom + ' has the narrowest bar — the least impact.'" },
      { "id": "c3", "text": "top + ' has the least effect on the outcome.'", "correct": "false", "why": "'The widest bar is the most influential, not the least.'" },
      { "id": "c4", "text": "'Every variable affects the outcome about equally.'", "correct": "false", "why": "'The bars differ a lot in width, so the sensitivities are not equal.'" }
    ],
    "explanation": "A tornado diagram ranks variables by how much they swing the outcome, widest at the top. Here that is {{top}} — the variable the result is most sensitive to."
  },
  {
    "schema": "figuregen/v1",
    "id": "dependency-types",
    "kind": "choice",
    "domain": "Process",
    "topic": "Dependency relationships",
    "difficulty": "medium",
    "viewBox": [320, 150],
    "prompt": "Which dependency relationship is shown between A and B?",
    "caption": "The dashed line links the dependent ends.",
    "vars": {
      "kind": { "pick": ["FS", "SS", "FF"] },
      "dA": { "int": [2, 4] },
      "dBraw": { "int": [2, 4] }
    },
    "derived": {
      "dB": "kind=='FF' ? min(dBraw, dA) : dBraw",
      "sB": "kind=='FS' ? (1 + dA) : (kind=='SS' ? 1 : (1 + dA - dB))",
      "linkT": "kind=='SS' ? 1 : (1 + dA)"
    },
    "draw": [
      { "op": "text", "x": 30, "y": 56, "text": "'A'", "size": 10, "anchor": "end" },
      { "op": "text", "x": 30, "y": 104, "text": "'B'", "size": 10, "anchor": "end" },
      { "op": "rect", "x": 76, "y": 44, "w": "dA*40", "h": 18, "rx": 3, "fill": "ink", "fillOpacity": 0.1, "width": 1.3 },
      { "op": "rect", "x": "36 + sB*40", "y": 92, "w": "dB*40", "h": 18, "rx": 3, "fill": "ink", "fillOpacity": 0.1, "width": 1.3 },
      { "op": "line", "x1": "36 + linkT*40", "y1": 62, "x2": "36 + linkT*40", "y2": 92, "width": 1.2, "dash": "3 3" },
      { "op": "text", "x": 160, "y": 138, "text": "'time →'", "size": 8, "anchor": "middle" }
    ],
    "choices": [
      { "id": "FS", "text": "'Finish-to-Start (B starts when A finishes)'", "correct": "kind=='FS'", "why": "kind=='FS' ? 'The dashed link ties exactly these two ends together.' : ''" },
      { "id": "SS", "text": "'Start-to-Start (B starts when A starts)'", "correct": "kind=='SS'", "why": "kind=='SS' ? 'The dashed link ties exactly these two ends together.' : ''" },
      { "id": "FF", "text": "'Finish-to-Finish (B finishes when A finishes)'", "correct": "kind=='FF'", "why": "kind=='FF' ? 'The dashed link ties exactly these two ends together.' : ''" },
      { "id": "SF", "text": "'Start-to-Finish (B finishes when A starts)'", "correct": "false", "why": "''" }
    ],
    "explanation": "The dashed link ties the two dependent ends together, which is {{kind=='FS' ? 'Finish-to-Start (B starts when A finishes)' : kind=='SS' ? 'Start-to-Start (B starts when A starts)' : 'Finish-to-Finish (B finishes when A finishes)'}}."
  },
  {
    "schema": "figuregen/v1",
    "id": "emv",
    "kind": "hotspot",
    "domain": "Business Environment",
    "topic": "Decision tree / EMV",
    "difficulty": "hard",
    "viewBox": [330, 200],
    "prompt": "Tap the decision branch with the higher expected monetary value (EMV).",
    "caption": "Square = decision; circles = chance nodes.",
    "vars": {
      "pAi": { "int": [5, 7] },
      "winAi": { "int": [8, 12] },
      "loseAi": { "int": [1, 3] },
      "pBi": { "int": [3, 4] },
      "winBi": { "int": [15, 22] },
      "loseBi": { "int": [0, 2] }
    },
    "guard": "(pAi*winAi - loseAi*(10-pAi)) > (pBi*winBi - loseBi*(10-pBi)) && abs((pAi*winAi - loseAi*(10-pAi)) - (pBi*winBi - loseBi*(10-pBi))) >= 4",
    "derived": {
      "pA": "pAi/10",
      "pAn": "round1(1 - pAi/10)",
      "pB": "pBi/10",
      "pBn": "round1(1 - pBi/10)",
      "winA": "winAi*10",
      "loseA": "0 - loseAi*10",
      "winB": "winBi*10",
      "loseB": "0 - loseBi*10",
      "emvA": "pAi*winAi - loseAi*(10-pAi)",
      "emvB": "pBi*winBi - loseBi*(10-pBi)",
      "winAs": "'+' + winA + 'k'",
      "loseAs": "loseA + 'k'",
      "winBs": "'+' + winB + 'k'",
      "loseBs": "loseB + 'k'",
      "emvAs": "'+' + emvA + 'k'",
      "emvBs": "'+' + emvB + 'k'"
    },
    "draw": [
      { "op": "rect", "x": 24, "y": 92, "w": 16, "h": 16, "width": 1.4 },
      { "op": "line", "x1": 40, "y1": 100, "x2": 150, "y2": 54, "width": 1.4 },
      { "op": "line", "x1": 40, "y1": 100, "x2": 150, "y2": 150, "width": 1.4 },
      { "op": "text", "x": 86, "y": 70, "text": "'Option A'", "size": 9, "anchor": "middle" },
      { "op": "text", "x": 86, "y": 138, "text": "'Option B'", "size": 9, "anchor": "middle" },
      { "op": "circle", "cx": 150, "cy": 54, "r": 7, "width": 1.4 },
      { "op": "circle", "cx": 150, "cy": 150, "r": 7, "width": 1.4 },
      { "op": "line", "x1": 157, "y1": 52, "x2": 250, "y2": 34, "width": 1.2 },
      { "op": "text", "x": 300, "y": 37, "text": "pA + ': ' + winAs", "size": 8, "anchor": "middle" },
      { "op": "line", "x1": 157, "y1": 56, "x2": 250, "y2": 78, "width": 1.2 },
      { "op": "text", "x": 300, "y": 81, "text": "pAn + ': ' + loseAs", "size": 8, "anchor": "middle" },
      { "op": "line", "x1": 157, "y1": 148, "x2": 250, "y2": 128, "width": 1.2 },
      { "op": "text", "x": 300, "y": 131, "text": "pB + ': ' + winBs", "size": 8, "anchor": "middle" },
      { "op": "line", "x1": 157, "y1": 152, "x2": 250, "y2": 172, "width": 1.2 },
      { "op": "text", "x": 300, "y": 175, "text": "pBn + ': ' + loseBs", "size": 8, "anchor": "middle" }
    ],
    "regions": [
      {
        "id": "'a'",
        "x": 40, "y": 48, "w": 120, "h": 40,
        "correct": "true",
        "label": "'Option A'",
        "why": "'EMV = ' + pA + '×' + winA + ' + ' + pAn + '×(' + loseA + ') = ' + emvAs + ' — the higher EMV.'"
      },
      {
        "id": "'b'",
        "x": 40, "y": 110, "w": 120, "h": 40,
        "correct": "false",
        "label": "'Option B'",
        "why": "'EMV = ' + pB + '×' + winB + ' + ' + pBn + '×(' + loseB + ') = ' + emvBs + ' — bigger upside, lower EMV.'"
      }
    ],
    "select": 1,
    "explanation": "EMV(A) = {{emvAs}} vs EMV(B) = {{emvBs}}. Option A wins despite B's larger best case — EMV weights each outcome by its probability."
  },
  {
    "schema": "figuregen/v1",
    "id": "dependency-gantt",
    "kind": "hotspot",
    "domain": "Process",
    "topic": "Sequence activities",
    "difficulty": "hard",
    "viewBox": [330, 214],
    "prompt": "The notes list how these tasks must be scheduled. Tap the bar that does NOT follow them.",
    "caption": "Check each bar against the dependency notes.",
    "vars": {
      "dA": { "int": [1, 3] },
      "dB": { "int": [1, 3] },
      "dC": { "int": [1, 3] },
      "dD": { "int": [1, 3] },
      "target": { "pick": ["B", "C", "D"] },
      "rBraw": { "int": [0, 2] },
      "rDraw": { "int": [0, 2] },
      "kRange": { "range": 10 }
    },
    "derived": {
      "drawnB": "target=='B' ? min(rBraw, dA-1) : dA",
      "drawnC": "target=='C' ? (dA+dB) : dA",
      "drawnD": "target=='D' ? (dA + min(rDraw, dB-1)) : (dA+dB)",
      "maxWk": "max([dA, drawnB+dB, drawnC+dC, drawnD+dD, dA+dB, dA+dC, dA+dB+dD])",
      "w": "224 / maxWk",
      "reasonBad": "target=='B' ? 'B overlaps A, but B must start only after A finishes.' : (target=='C' ? 'C starts after B, but it should start together with B.' : 'D overlaps B, but D must start only after B finishes.')",
      "notesArr": "['B starts after A finishes.', 'C starts together with B.', 'D starts after B finishes.']",
      "rows": "[['A', 0, dA, false, ''], ['B', drawnB, dB, target=='B', 'B overlaps A, but B must start only after A finishes.'], ['C', drawnC, dC, target=='C', 'C starts after B, but it should start together with B.'], ['D', drawnD, dD, target=='D', 'D overlaps B, but D must start only after B finishes.']]"
    },
    "draw": [
      { "op": "text", "x": 12, "y": 18, "text": "'Dependencies:'", "size": 9, "anchor": "start" },
      {
        "op": "repeat",
        "over": "notesArr",
        "as": "note",
        "do": [
          { "op": "text", "x": 20, "y": "34 + i*14", "text": "'• ' + note", "size": 8.5, "anchor": "start" }
        ]
      },
      {
        "op": "repeat",
        "over": "kRange",
        "as": "k",
        "do": [
          { "op": "line", "x1": "88 + k*w", "y1": 72, "x2": "88 + k*w", "y2": 182, "width": 0.5, "opacity": "k <= maxWk ? 0.45 : 0" },
          { "op": "text", "x": "88 + k*w", "y": 196, "text": "k <= maxWk ? ('' + k) : ''", "size": 7, "anchor": "middle" }
        ]
      },
      {
        "op": "repeat",
        "over": "rows",
        "as": "b",
        "do": [
          { "op": "text", "x": 80, "y": "88 + i*28", "text": "b[0]", "size": 9, "anchor": "end" },
          { "op": "rect", "x": "88 + b[1]*w", "y": "78 + i*28", "w": "b[2]*w", "h": 14, "rx": 2.5, "fill": "ink", "fillOpacity": 0.12, "width": 1.3 }
        ]
      },
      { "op": "text", "x": 200, "y": 208, "text": "'weeks →'", "size": 8, "anchor": "middle" }
    ],
    "regions": {
      "repeat": "rows",
      "as": "b",
      "items": [
        {
          "id": "b[0]",
          "x": 72,
          "y": "74 + i*28",
          "w": 248,
          "h": 22,
          "correct": "b[3]",
          "label": "b[0]",
          "why": "b[3] ? b[4] : 'Matches its dependency note.'"
        }
      ]
    },
    "select": 1,
    "explanation": "{{reasonBad}} The other three bars honour their notes."
  }
]
