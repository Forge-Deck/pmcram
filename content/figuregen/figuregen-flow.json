[
  {
    "schema": "figuregen/v1",
    "id": "pareto",
    "kind": "hotspot",
    "domain": "Process",
    "topic": "Pareto analysis",
    "difficulty": "medium",
    "freeSelect": true,
    "viewBox": [302, 188],
    "prompt": "{{context}}, ranked highest-first. Under the 80/20 rule, tap every category in the vital few — fix those first to clear ~80% of the total.",
    "caption": "Bars = counts; line = cumulative %.",
    "vars": {
      "v0": { "int": [44, 64] },
      "v1": { "int": [24, 36] },
      "v2": { "int": [12, 20] },
      "v3": { "int": [6, 11] },
      "v4": { "int": [3, 6] },
      "v5": { "int": [2, 4] },
      "cats": { "sample": ["Reqs", "Test data", "Env", "UI", "Training", "Docs", "Config", "Access", "Data qual", "Vendor", "Comms", "Tooling"], "count": 6 },
      "context": { "pick": ["Defect causes", "Customer complaints", "Support tickets", "Cost drivers", "Rework reasons"] }
    },
    "derived": {
      "s": "[v0, v1, v2, v3, v4, v5]",
      "total": "sum(s)",
      "t8": "0.8*total",
      "cum": "[s[0], s[0]+s[1], s[0]+s[1]+s[2], s[0]+s[1]+s[2]+s[3], s[0]+s[1]+s[2]+s[3]+s[4], total]",
      "cutoff": "cum[0]>=t8?0:cum[1]>=t8?1:cum[2]>=t8?2:cum[3]>=t8?3:cum[4]>=t8?4:5",
      "maxv": "s[0]"
    },
    "draw": [
      { "op": "line", "x1": 40, "y1": 166, "x2": 296, "y2": 166, "width": 1.3 },
      { "op": "line", "x1": 40, "y1": 26, "x2": 40, "y2": 166, "width": 1.3 },
      { "op": "line", "x1": 40, "y1": 54, "x2": 296, "y2": 54, "width": 1, "dash": "4 4" },
      { "op": "text", "x": 296, "y": 51, "text": "'80%'", "size": 8, "anchor": "end" },
      {
        "op": "repeat",
        "over": "s",
        "as": "h",
        "do": [
          { "op": "rect", "x": "44 + i*42", "y": "166 - h/maxv*130", "w": 36, "h": "h/maxv*130", "rx": 3, "fill": "ink", "fillOpacity": 0.1, "width": 1.2 },
          { "op": "text", "x": "44 + i*42 + 18", "y": 182, "text": "cats[i]", "size": 7, "anchor": "middle" }
        ]
      },
      {
        "op": "polyline",
        "points": [62, "166 - cum[0]/total*140", 104, "166 - cum[1]/total*140", 146, "166 - cum[2]/total*140", 188, "166 - cum[3]/total*140", 230, "166 - cum[4]/total*140", 272, "166 - cum[5]/total*140"],
        "width": 1.6
      },
      {
        "op": "repeat",
        "over": "cum",
        "as": "cv",
        "do": [{ "op": "circle", "cx": "62 + i*42", "cy": "166 - cv/total*140", "r": 2.4, "fill": "ink" }]
      }
    ],
    "regions": {
      "repeat": "s",
      "as": "h",
      "items": [
        {
          "id": "i",
          "x": "44 + i*42",
          "y": 26,
          "w": 36,
          "h": 140,
          "correct": "i <= cutoff",
          "label": "cats[i]",
          "why": "i <= cutoff ? ('Cumulative ' + round(cum[i]/total*100) + '% — in the vital few, fix first.') : ('Cumulative ' + round(cum[i]/total*100) + '% — trivial many, lower priority.')"
        }
      ]
    },
    "explanation": "The vital few run up to where the cumulative line first crosses 80% (here \"{{cats[cutoff]}}\"). Fixing those clears ~80% of the total, so they take priority over the trivial many."
  },
  {
    "schema": "figuregen/v1",
    "id": "kanban",
    "kind": "hotspot",
    "domain": "Process",
    "topic": "Kanban / flow",
    "difficulty": "medium",
    "freeSelect": true,
    "viewBox": [320, 196],
    "prompt": "Work is piling up on the board. Each column shows its WIP limit — tap every column that has breached it (the flow constraints to clear before pulling in more work).",
    "caption": "Cards stacked per column; WIP = the column's limit.",
    "vars": {
      "overFlags": { "sampleInt": [0, 1], "count": 3 },
      "lim": { "sampleInt": [3, 4], "count": 3 },
      "und": { "sampleInt": [1, 4], "count": 3 },
      "ovr": { "int": [1, 2] },
      "back": { "int": [2, 5] },
      "done": { "int": [2, 5] },
      "names": { "value": ["Backlog", "Analysis", "Dev", "Test", "Done"] },
      "slots": { "range": 6 },
      "limIdx": { "value": [1, 2, 3] }
    },
    "guard": "count([overFlags[0]==1,overFlags[1]==1,overFlags[2]==1]) >= 1 && count([overFlags[0]==1,overFlags[1]==1,overFlags[2]==1]) <= 2",
    "derived": {
      "limArr": "[0, lim[0], lim[1], lim[2], 0]",
      "cards": "[back, overFlags[0]==1 ? lim[0]+ovr : min(und[0],lim[0]), overFlags[1]==1 ? lim[1]+ovr : min(und[1],lim[1]), overFlags[2]==1 ? lim[2]+ovr : min(und[2],lim[2]), done]",
      "nOver": "count([overFlags[0]==1,overFlags[1]==1,overFlags[2]==1])"
    },
    "draw": [
      {
        "op": "repeat",
        "over": "cards",
        "as": "cnt",
        "do": [
          { "op": "rect", "x": "14 + i*60", "y": 40, "w": 58, "h": 144, "rx": 3, "width": 1 },
          { "op": "text", "x": "14 + i*60 + 29", "y": 24, "text": "names[i]", "size": 8, "anchor": "middle" },
          { "op": "text", "x": "14 + i*60 + 29", "y": 35, "text": "limArr[i] > 0 ? 'WIP ' + limArr[i] : ''", "size": 7, "anchor": "middle" }
        ]
      },
      {
        "op": "repeat",
        "over": "slots",
        "as": "sl",
        "do": [
          {
            "op": "repeat",
            "over": "cards",
            "as": "cnt",
            "do": [
              { "op": "rect", "x": "14 + i*60 + 8", "y": "48 + sl*20", "w": "sl < cnt ? 42 : 0", "h": "sl < cnt ? 15 : 0", "rx": 2, "fill": "ink", "fillOpacity": 0.1, "width": 1 }
            ]
          }
        ]
      }
    ],
    "regions": {
      "repeat": "limIdx",
      "as": "ci",
      "items": [
        {
          "id": "ci",
          "x": "14 + ci*60",
          "y": 40,
          "w": 58,
          "h": 144,
          "correct": "overFlags[ci-1]==1",
          "label": "names[ci]",
          "why": "overFlags[ci-1]==1 ? (cards[ci] + ' cards against a WIP limit of ' + limArr[ci] + ' — over the limit.') : (cards[ci] + ' of ' + limArr[ci] + ' — within its WIP limit.')"
        }
      ]
    },
    "explanation": "{{nOver}} column(s) exceed their WIP limit — those are the flow constraints. Clear them before pulling in new work, rather than feeding the upstream columns."
  },
  {
    "schema": "figuregen/v1",
    "id": "engagement-gap",
    "kind": "hotspot",
    "domain": "People",
    "topic": "Stakeholder engagement",
    "difficulty": "medium",
    "freeSelect": true,
    "viewBox": [322, 176],
    "prompt": "C = current, D = desired engagement. Tap every stakeholder that must move up 2+ levels — those need a focused engagement plan before the next phase gate.",
    "caption": "Columns: Unaware → Leading.",
    "vars": {
      "people": { "sample": ["Sponsor", "Regulator", "End users", "Vendor", "Ops team", "Steering"], "count": 4 },
      "cur": { "sampleInt": [1, 4], "count": 4 },
      "desRaw": { "sampleInt": [1, 5], "count": 4 },
      "levels": { "value": ["Unaware", "Resistant", "Neutral", "Supportive", "Leading"] },
      "verts": { "range": 6 }
    },
    "guard": "count([max(0,desRaw[0]-cur[0])>=2,max(0,desRaw[1]-cur[1])>=2,max(0,desRaw[2]-cur[2])>=2,max(0,desRaw[3]-cur[3])>=2]) >= 1 && count([max(0,desRaw[0]-cur[0])>=2,max(0,desRaw[1]-cur[1])>=2,max(0,desRaw[2]-cur[2])>=2,max(0,desRaw[3]-cur[3])>=2]) <= 3",
    "derived": {
      "des": "[max(cur[0],desRaw[0]),max(cur[1],desRaw[1]),max(cur[2],desRaw[2]),max(cur[3],desRaw[3])]",
      "gaps": "[des[0]-cur[0],des[1]-cur[1],des[2]-cur[2],des[3]-cur[3]]",
      "nBig": "count([des[0]-cur[0]>=2,des[1]-cur[1]>=2,des[2]-cur[2]>=2,des[3]-cur[3]>=2])"
    },
    "draw": [
      {
        "op": "repeat",
        "over": "verts",
        "as": "cc",
        "do": [{ "op": "line", "x1": "96 + i*44", "y1": 40, "x2": "96 + i*44", "y2": 160, "width": 0.4 }]
      },
      {
        "op": "repeat",
        "over": "people",
        "as": "p",
        "do": [
          { "op": "line", "x1": 96, "y1": "40 + i*30", "x2": 316, "y2": "40 + i*30", "width": 0.4 },
          { "op": "text", "x": 88, "y": "40 + i*30 + 18", "text": "p", "size": 8, "anchor": "end" },
          { "op": "text", "x": "118 + (cur[i]-1)*44", "y": "40 + i*30 + 18.5", "text": "cur[i]==des[i] ? 'CD' : 'C'", "size": 9.5, "anchor": "middle" },
          { "op": "text", "x": "118 + (des[i]-1)*44", "y": "40 + i*30 + 18.5", "text": "cur[i]==des[i] ? '' : 'D'", "size": 9.5, "anchor": "middle" }
        ]
      },
      {
        "op": "repeat",
        "over": "levels",
        "as": "lv",
        "do": [{ "op": "text", "x": "118 + i*44", "y": 32, "text": "lv", "size": 6.5, "anchor": "middle" }]
      }
    ],
    "regions": {
      "repeat": "people",
      "as": "p",
      "items": [
        {
          "id": "'s' + i",
          "x": 6,
          "y": "40 + i*30",
          "w": 310,
          "h": 30,
          "correct": "gaps[i] >= 2",
          "label": "p",
          "why": "levels[cur[i]-1] + ' → ' + levels[des[i]-1] + ' (gap ' + gaps[i] + ')' + (gaps[i]>=2 ? ' — needs a focused plan.' : ' — minor gap.')"
        }
      ]
    },
    "explanation": "{{nBig}} stakeholder(s) have a 2+ level gap — they need active engagement work before the gate. A 0–1 level gap is minor and can be managed passively."
  }
]
