[
  {
    "schema": "figuregen/v1",
    "id": "pareto",
    "kind": "hotspot",
    "domain": "Process",
    "topic": "Pareto analysis",
    "difficulty": "medium",
    "viewBox": [302, 188],
    "prompt": "Tap the bar where the cumulative line first reaches 80% — the vital-few cut-off.",
    "caption": "Bars = counts; line = cumulative %.",
    "vars": {
      "c": { "sampleInt": [6, 40], "count": 6 },
      "cats": { "value": ["Reqs", "Test data", "Env", "UI", "Training", "Docs"] }
    },
    "guard": "max(c) < 0.8*sum(c) && min(c) <= 0.2*sum(c)",
    "derived": {
      "p1": "[max(c[0],c[1]),min(c[0],c[1]),max(c[2],c[3]),min(c[2],c[3]),max(c[4],c[5]),min(c[4],c[5])]",
      "p2": "[p1[0],max(p1[1],p1[2]),min(p1[1],p1[2]),max(p1[3],p1[4]),min(p1[3],p1[4]),p1[5]]",
      "p3": "[max(p2[0],p2[1]),min(p2[0],p2[1]),max(p2[2],p2[3]),min(p2[2],p2[3]),max(p2[4],p2[5]),min(p2[4],p2[5])]",
      "p4": "[p3[0],max(p3[1],p3[2]),min(p3[1],p3[2]),max(p3[3],p3[4]),min(p3[3],p3[4]),p3[5]]",
      "p5": "[max(p4[0],p4[1]),min(p4[0],p4[1]),max(p4[2],p4[3]),min(p4[2],p4[3]),max(p4[4],p4[5]),min(p4[4],p4[5])]",
      "s": "[p5[0],max(p5[1],p5[2]),min(p5[1],p5[2]),max(p5[3],p5[4]),min(p5[3],p5[4]),p5[5]]",
      "total": "sum(s)",
      "t8": "0.8*total",
      "cum": "[s[0],s[0]+s[1],s[0]+s[1]+s[2],s[0]+s[1]+s[2]+s[3],s[0]+s[1]+s[2]+s[3]+s[4],total]",
      "cutoff": "cum[0]>=t8?0:cum[1]>=t8?1:cum[2]>=t8?2:cum[3]>=t8?3:cum[4]>=t8?4:5",
      "maxv": "s[0]"
    },
    "draw": [
      { "op": "line", "x1": 40, "y1": 166, "x2": 296, "y2": 166, "width": 1.3 },
      { "op": "line", "x1": 40, "y1": 26, "x2": 40, "y2": 166, "width": 1.3 },
      { "op": "line", "x1": 40, "y1": 54, "x2": 296, "y2": 54, "width": 1, "dash": "4 4" },
      { "op": "text", "x": 296, "y": 51, "text": "'80%'", "size": 8, "anchor": "end" },
      {
        "op": "repeat",
        "over": "s",
        "as": "h",
        "do": [
          { "op": "rect", "x": "44 + i*42", "y": "166 - h/maxv*130", "w": 36, "h": "h/maxv*130", "rx": 3, "fill": "ink", "fillOpacity": 0.1, "width": 1.2 },
          { "op": "text", "x": "44 + i*42 + 18", "y": 182, "text": "cats[i]", "size": 7, "anchor": "middle" }
        ]
      },
      {
        "op": "polyline",
        "points": [62, "166 - cum[0]/total*140", 104, "166 - cum[1]/total*140", 146, "166 - cum[2]/total*140", 188, "166 - cum[3]/total*140", 230, "166 - cum[4]/total*140", 272, "166 - cum[5]/total*140"],
        "width": 1.6
      },
      {
        "op": "repeat",
        "over": "cum",
        "as": "cv",
        "do": [{ "op": "circle", "cx": "62 + i*42", "cy": "166 - cv/total*140", "r": 2.4, "fill": "ink" }]
      }
    ],
    "regions": {
      "repeat": "s",
      "as": "h",
      "items": [
        {
          "id": "i",
          "x": "44 + i*42",
          "y": 26,
          "w": 36,
          "h": 140,
          "correct": "i == cutoff",
          "label": "cats[i]",
          "why": "'Cumulative ' + round(cum[i]/total*100) + '% here' + (i==cutoff ? ' — first to reach 80%.' : '.')"
        }
      ]
    },
    "explanation": "Reading the cumulative line, 80% is first crossed at \"{{cats[cutoff]}}\". Those categories up to it are the vital few to tackle first."
  },
  {
    "schema": "figuregen/v1",
    "id": "kanban",
    "kind": "hotspot",
    "domain": "Process",
    "topic": "Kanban / flow",
    "difficulty": "medium",
    "viewBox": [320, 196],
    "prompt": "Each flow column shows its WIP limit. Tap the column that has breached its limit.",
    "caption": "Cards stacked per column; WIP = the column's limit.",
    "vars": {
      "over": { "pick": [1, 2, 3] },
      "lim": { "sampleInt": [3, 4], "count": 3 },
      "und": { "sampleInt": [1, 4], "count": 3 },
      "ovr": { "int": [1, 2] },
      "back": { "int": [2, 5] },
      "done": { "int": [2, 5] },
      "names": { "value": ["Backlog", "Analysis", "Dev", "Test", "Done"] },
      "slots": { "range": 6 },
      "limIdx": { "value": [1, 2, 3] }
    },
    "derived": {
      "limArr": "[0, lim[0], lim[1], lim[2], 0]",
      "cards": "[back, (1==over ? lim[0]+ovr : min(und[0],lim[0])), (2==over ? lim[1]+ovr : min(und[1],lim[1])), (3==over ? lim[2]+ovr : min(und[2],lim[2])), done]"
    },
    "draw": [
      {
        "op": "repeat",
        "over": "cards",
        "as": "cnt",
        "do": [
          { "op": "rect", "x": "14 + i*60", "y": 40, "w": 58, "h": 144, "rx": 3, "width": 1 },
          { "op": "text", "x": "14 + i*60 + 29", "y": 24, "text": "names[i]", "size": 8, "anchor": "middle" },
          { "op": "text", "x": "14 + i*60 + 29", "y": 35, "text": "limArr[i] > 0 ? 'WIP ' + limArr[i] : ''", "size": 7, "anchor": "middle" }
        ]
      },
      {
        "op": "repeat",
        "over": "slots",
        "as": "sl",
        "do": [
          {
            "op": "repeat",
            "over": "cards",
            "as": "cnt",
            "do": [
              { "op": "rect", "x": "14 + i*60 + 8", "y": "48 + sl*20", "w": "sl < cnt ? 42 : 0", "h": "sl < cnt ? 15 : 0", "rx": 2, "fill": "ink", "fillOpacity": 0.1, "width": 1 }
            ]
          }
        ]
      }
    ],
    "regions": {
      "repeat": "limIdx",
      "as": "ci",
      "items": [
        {
          "id": "ci",
          "x": "14 + ci*60",
          "y": 40,
          "w": 58,
          "h": 144,
          "correct": "ci == over",
          "label": "names[ci]",
          "why": "ci == over ? (cards[ci] + ' cards against a WIP limit of ' + limArr[ci] + ' — over the limit.') : (cards[ci] + ' of ' + limArr[ci] + ' — within its WIP limit.')"
        }
      ]
    },
    "select": 1,
    "explanation": "The {{names[over]}} column holds {{cards[over]}} cards against a WIP limit of {{limArr[over]}} — it has breached its limit and is the flow bottleneck to clear."
  },
  {
    "schema": "figuregen/v1",
    "id": "engagement-gap",
    "kind": "hotspot",
    "domain": "People",
    "topic": "Stakeholder engagement",
    "difficulty": "medium",
    "viewBox": [322, 176],
    "prompt": "C = current, D = desired engagement. Tap the stakeholder with the largest gap to close.",
    "caption": "Columns: Unaware → Leading.",
    "vars": {
      "people": { "sample": ["Sponsor", "Regulator", "End users", "Vendor", "Ops team", "Steering"], "count": 4 },
      "cur": { "sampleInt": [1, 4], "count": 4 },
      "desRaw": { "sampleInt": [1, 5], "count": 4 },
      "levels": { "value": ["Unaware", "Resistant", "Neutral", "Supportive", "Leading"] },
      "verts": { "range": 6 }
    },
    "guard": "max([max(0,desRaw[0]-cur[0]),max(0,desRaw[1]-cur[1]),max(0,desRaw[2]-cur[2]),max(0,desRaw[3]-cur[3])]) >= 2 && count([max(0,desRaw[0]-cur[0])==max([max(0,desRaw[0]-cur[0]),max(0,desRaw[1]-cur[1]),max(0,desRaw[2]-cur[2]),max(0,desRaw[3]-cur[3])]),max(0,desRaw[1]-cur[1])==max([max(0,desRaw[0]-cur[0]),max(0,desRaw[1]-cur[1]),max(0,desRaw[2]-cur[2]),max(0,desRaw[3]-cur[3])]),max(0,desRaw[2]-cur[2])==max([max(0,desRaw[0]-cur[0]),max(0,desRaw[1]-cur[1]),max(0,desRaw[2]-cur[2]),max(0,desRaw[3]-cur[3])]),max(0,desRaw[3]-cur[3])==max([max(0,desRaw[0]-cur[0]),max(0,desRaw[1]-cur[1]),max(0,desRaw[2]-cur[2]),max(0,desRaw[3]-cur[3])])]) == 1",
    "derived": {
      "des": "[max(cur[0],desRaw[0]),max(cur[1],desRaw[1]),max(cur[2],desRaw[2]),max(cur[3],desRaw[3])]",
      "gaps": "[des[0]-cur[0],des[1]-cur[1],des[2]-cur[2],des[3]-cur[3]]",
      "worst": "argmax(gaps)"
    },
    "draw": [
      {
        "op": "repeat",
        "over": "verts",
        "as": "cc",
        "do": [{ "op": "line", "x1": "96 + i*44", "y1": 40, "x2": "96 + i*44", "y2": 160, "width": 0.4 }]
      },
      {
        "op": "repeat",
        "over": "people",
        "as": "p",
        "do": [
          { "op": "line", "x1": 96, "y1": "40 + i*30", "x2": 316, "y2": "40 + i*30", "width": 0.4 },
          { "op": "text", "x": 88, "y": "40 + i*30 + 18", "text": "p", "size": 8, "anchor": "end" },
          { "op": "text", "x": "118 + (cur[i]-1)*44", "y": "40 + i*30 + 18.5", "text": "cur[i]==des[i] ? 'CD' : 'C'", "size": 9.5, "anchor": "middle" },
          { "op": "text", "x": "118 + (des[i]-1)*44", "y": "40 + i*30 + 18.5", "text": "cur[i]==des[i] ? '' : 'D'", "size": 9.5, "anchor": "middle" }
        ]
      },
      {
        "op": "repeat",
        "over": "levels",
        "as": "lv",
        "do": [{ "op": "text", "x": "118 + i*44", "y": 32, "text": "lv", "size": 6.5, "anchor": "middle" }]
      }
    ],
    "regions": {
      "repeat": "people",
      "as": "p",
      "items": [
        {
          "id": "'s' + i",
          "x": 6,
          "y": "40 + i*30",
          "w": 310,
          "h": 30,
          "correct": "i == worst",
          "label": "p",
          "why": "levels[cur[i]-1] + ' → ' + levels[des[i]-1] + ' (gap ' + gaps[i] + ')' + (i==worst ? ' — the largest.' : '.')"
        }
      ]
    },
    "explanation": "{{people[worst]}} must move {{gaps[worst]}} levels ({{levels[cur[worst]-1]}} → {{levels[des[worst]-1]}}), the biggest gap — so it needs the most engagement effort."
  }
]
