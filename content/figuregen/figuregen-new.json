[
  {
    "schema": "figuregen/v1",
    "id": "activity-network-noncritical",
    "kind": "hotspot",
    "domain": "Process",
    "topic": "Schedule",
    "difficulty": "medium",
    "viewBox": [320, 200],
    "prompt": "On this activity network, tap the activity that is NOT on the critical path.",
    "caption": "Activity-on-node network. Each box shows its activity and duration in days.",
    "vars": {
      "dA": { "int": [2, 8] },
      "dB": { "int": [2, 9] },
      "dC": { "int": [2, 9] },
      "dD": { "int": [2, 8] }
    },
    "guard": "dB != dC",
    "derived": {
      "p1": "dA + dB + dD",
      "p2": "dA + dC + dD",
      "T": "max(p1, p2)"
    },
    "draw": [
      { "op": "arrow", "x1": 74, "y1": 90, "x2": 131, "y2": 55, "width": 1.3, "head": 8 },
      { "op": "arrow", "x1": 74, "y1": 110, "x2": 131, "y2": 145, "width": 1.3, "head": 8 },
      { "op": "arrow", "x1": 189, "y1": 55, "x2": 246, "y2": 90, "width": 1.3, "head": 8 },
      { "op": "arrow", "x1": 189, "y1": 145, "x2": 246, "y2": 110, "width": 1.3, "head": 8 },
      { "op": "rect", "x": 16, "y": 78, "w": 58, "h": 44, "rx": 4, "width": 1.4 },
      { "op": "text", "x": 45, "y": 104, "text": "'A · ' + dA + 'd'", "size": 11, "anchor": "middle" },
      { "op": "rect", "x": 131, "y": 28, "w": 58, "h": 44, "rx": 4, "width": 1.4 },
      { "op": "text", "x": 160, "y": 54, "text": "'B · ' + dB + 'd'", "size": 11, "anchor": "middle" },
      { "op": "rect", "x": 131, "y": 128, "w": 58, "h": 44, "rx": 4, "width": 1.4 },
      { "op": "text", "x": 160, "y": 154, "text": "'C · ' + dC + 'd'", "size": 11, "anchor": "middle" },
      { "op": "rect", "x": 246, "y": 78, "w": 58, "h": 44, "rx": 4, "width": 1.4 },
      { "op": "text", "x": 275, "y": 104, "text": "'D · ' + dD + 'd'", "size": 11, "anchor": "middle" },
      { "op": "text", "x": 160, "y": 192, "text": "'path A-B-D = ' + p1 + ' days   ·   path A-C-D = ' + p2 + ' days'", "size": 9, "anchor": "middle" }
    ],
    "regions": [
      {
        "id": "'A'",
        "x": 16, "y": 78, "w": 58, "h": 44,
        "label": "'A'",
        "why": "'Shared by both paths — always on the critical path with zero float.'"
      },
      {
        "id": "'B'",
        "x": 131, "y": 28, "w": 58, "h": 44,
        "correct": "dB < dC",
        "label": "'B'",
        "why": "dB < dC ? ('On the shorter path A-B-D (' + p1 + 'd); it carries ' + (p2 - p1) + 'd of float, so it is off the critical path.') : ('On the critical path A-B-D (' + p1 + 'd) — zero float.')"
      },
      {
        "id": "'C'",
        "x": 131, "y": 128, "w": 58, "h": 44,
        "correct": "dC < dB",
        "label": "'C'",
        "why": "dC < dB ? ('On the shorter path A-C-D (' + p2 + 'd); it carries ' + (p1 - p2) + 'd of float, so it is off the critical path.') : ('On the critical path A-C-D (' + p2 + 'd) — zero float.')"
      },
      {
        "id": "'D'",
        "x": 246, "y": 78, "w": 58, "h": 44,
        "label": "'D'",
        "why": "'Shared by both paths — always on the critical path with zero float.'"
      }
    ],
    "explanation": "The critical path is the longest path through the network: {{p1 > p2 ? 'A-B-D' : 'A-C-D'}} = {{T}} days, whose activities have zero float. {{p1 > p2 ? 'C' : 'B'}} sits on the shorter {{p1 > p2 ? 'A-C-D' : 'A-B-D'}} path ({{min(p1, p2)}} days), so it has {{abs(p1 - p2)}} day(s) of float and is not critical."
  },
  {
    "schema": "figuregen/v1",
    "id": "risk-matrix-priority-cell",
    "kind": "hotspot",
    "domain": "Process",
    "topic": "Risk",
    "difficulty": "easy",
    "viewBox": [300, 205],
    "prompt": "On this probability-and-impact matrix, tap the cell for the highest-priority risk.",
    "caption": "Probability up the side, impact across the bottom. Priority = probability × impact.",
    "vars": {
      "cells": { "sampleInt": [0, 8], "count": 3, "unique": true },
      "g9": { "range": 9 }
    },
    "guard": "count([(floor(cells[0]/3)+1)*(cells[0]%3+1)==max((floor(cells[0]/3)+1)*(cells[0]%3+1),(floor(cells[1]/3)+1)*(cells[1]%3+1),(floor(cells[2]/3)+1)*(cells[2]%3+1)),(floor(cells[1]/3)+1)*(cells[1]%3+1)==max((floor(cells[0]/3)+1)*(cells[0]%3+1),(floor(cells[1]/3)+1)*(cells[1]%3+1),(floor(cells[2]/3)+1)*(cells[2]%3+1)),(floor(cells[2]/3)+1)*(cells[2]%3+1)==max((floor(cells[0]/3)+1)*(cells[0]%3+1),(floor(cells[1]/3)+1)*(cells[1]%3+1),(floor(cells[2]/3)+1)*(cells[2]%3+1))])==1",
    "derived": {
      "P": "[floor(cells[0]/3)+1, floor(cells[1]/3)+1, floor(cells[2]/3)+1]",
      "Imp": "[cells[0]%3+1, cells[1]%3+1, cells[2]%3+1]",
      "prod": "[P[0]*Imp[0], P[1]*Imp[1], P[2]*Imp[2]]",
      "wi": "argmax(prod)"
    },
    "draw": [
      {
        "op": "repeat",
        "over": "g9",
        "as": "g",
        "do": [
          { "op": "rect", "x": "70 + (g%3)*60", "y": "30 + (2 - floor(g/3))*46", "w": 60, "h": 46, "width": 0.5 }
        ]
      },
      { "op": "text", "x": 64, "y": 58, "text": "'High'", "size": 9, "anchor": "end" },
      { "op": "text", "x": 64, "y": 104, "text": "'Med'", "size": 9, "anchor": "end" },
      { "op": "text", "x": 64, "y": 150, "text": "'Low'", "size": 9, "anchor": "end" },
      { "op": "text", "x": 30, "y": 99, "text": "'Probability'", "size": 10, "anchor": "middle", "rotate": -90 },
      { "op": "text", "x": 100, "y": 185, "text": "'Low'", "size": 9, "anchor": "middle" },
      { "op": "text", "x": 160, "y": 185, "text": "'Med'", "size": 9, "anchor": "middle" },
      { "op": "text", "x": 220, "y": 185, "text": "'High'", "size": 9, "anchor": "middle" },
      { "op": "text", "x": 160, "y": 200, "text": "'Impact'", "size": 10, "anchor": "middle" },
      {
        "op": "repeat",
        "over": "cells",
        "as": "cell",
        "do": [
          { "op": "circle", "cx": "70 + (cell%3)*60 + 30", "cy": "30 + (2 - floor(cell/3))*46 + 23", "r": 12, "color": "ink", "width": 1.4 },
          { "op": "text", "x": "70 + (cell%3)*60 + 30", "y": "30 + (2 - floor(cell/3))*46 + 26.5", "text": "'R' + (i+1)", "size": 9, "anchor": "middle" }
        ]
      }
    ],
    "regions": {
      "repeat": "cells",
      "as": "cell",
      "items": [
        {
          "id": "'r' + i",
          "x": "70 + (cell%3)*60",
          "y": "30 + (2 - floor(cell/3))*46",
          "w": 60,
          "h": 46,
          "correct": "i == wi",
          "label": "'R' + (i+1)",
          "why": "i == wi ? ('Probability ' + P[i] + ' × impact ' + Imp[i] + ' = ' + prod[i] + ' — the highest-priority risk.') : ('Probability ' + P[i] + ' × impact ' + Imp[i] + ' = ' + prod[i] + ' — not the highest.')"
        }
      ]
    },
    "explanation": "Risk priority rises with probability × impact. R{{wi+1}} scores {{prod[wi]}}, the highest of the three risks, so it is the top priority and needs a response now."
  },
