          { "op": "text", "x": "qx[i] + 70", "y": "qy[i] + 44", "text": "names[dom]", "size": 12, "anchor": "middle" },
          { "op": "text", "x": "qx[i] + 70", "y": "qy[i] + 60", "text": "appr[dom]", "size": 8, "anchor": "middle" }
        ]
      }
    ],
    "regions": {
      "repeat": "order",
      "as": "dom",
      "items": [
        {
          "id": "'q' + i",
          "x": "qx[i]",
          "y": "qy[i]",
          "w": 140,
          "h": 88,
          "correct": "dom == target",
          "label": "names[dom]",
          "why": "dom == target ? ('Correct — ' + names[dom] + ': ' + scen[dom]) : ('That is ' + names[dom] + ' (' + appr[dom] + ') — a different domain.')"
        }
      ]
    },
    "explanation": "{{names[target]}} fits: {{scen[target]}} The approach is {{appr[target]}}."
  },
