  {
    "schema": "figuregen/v1",
    "id": "gantt-milestone-spot",
    "kind": "hotspot",
    "domain": "Process",
    "topic": "Schedule",
    "difficulty": "medium",
    "viewBox": [320, 175],
    "prompt": "These tasks run back-to-back. Two milestones sit on the schedule — tap the one that marks {{mode == 1 ? 'project completion' : 'the project kickoff'}}.",
    "vars": {
      "mPair": { "sample": [0, 1, 2, 3, 4], "count": 2 },
      "d": { "sampleInt": [2, 4], "count": 5 },
      "names": { "sample": ["Design", "Build", "Test", "Deploy", "Review", "Plan", "Sign-off", "Go-live", "Launch", "Release"], "count": 5 },
      "mode": { "pick": [0, 1] },
      "r5": { "range": 5 }
    },
    "guard": "abs(mPair[0] - mPair[1]) >= 2",
    "derived": {
      "dur": "[(0==mPair[0]||0==mPair[1])?0:d[0], (1==mPair[0]||1==mPair[1])?0:d[1], (2==mPair[0]||2==mPair[1])?0:d[2], (3==mPair[0]||3==mPair[1])?0:d[3], (4==mPair[0]||4==mPair[1])?0:d[4]]",
      "starts": "[0, dur[0], dur[0]+dur[1], dur[0]+dur[1]+dur[2], dur[0]+dur[1]+dur[2]+dur[3]]",
      "total": "dur[0]+dur[1]+dur[2]+dur[3]+dur[4]",
      "W": "200 / max(total, 1)",
      "laterRow": "starts[mPair[1]] > starts[mPair[0]] ? mPair[1] : mPair[0]",
      "earlierRow": "starts[mPair[1]] > starts[mPair[0]] ? mPair[0] : mPair[1]",
      "target": "mode == 1 ? laterRow : earlierRow"
    },
    "draw": [
      { "op": "line", "x1": 86, "y1": 16, "x2": 86, "y2": 160, "width": 1 },
      {
        "op": "repeat",
        "over": "r5",
        "do": [
          { "op": "text", "x": 10, "y": "28 + i*28 + 11", "text": "names[i]", "size": 9, "anchor": "start" },
          { "op": "rect", "x": "88 + starts[i]*W", "y": "28 + i*28", "w": "(i == mPair[0] || i == mPair[1]) ? 0 : dur[i]*W", "h": 14, "rx": 3, "fill": "blue", "color": "blue", "width": "(i == mPair[0] || i == mPair[1]) ? 0 : 1.3" },
          {
            "op": "polygon",
            "points": [
              "(i == mPair[0] || i == mPair[1]) ? (88 + starts[i]*W) : -20",
              "28 + i*28 + 7 - ((i == mPair[0] || i == mPair[1]) ? 8 : 0)",
              "((i == mPair[0] || i == mPair[1]) ? (88 + starts[i]*W) : -20) + ((i == mPair[0] || i == mPair[1]) ? 8 : 0)",
              "28 + i*28 + 7",
              "(i == mPair[0] || i == mPair[1]) ? (88 + starts[i]*W) : -20",
              "28 + i*28 + 7 + ((i == mPair[0] || i == mPair[1]) ? 8 : 0)",
              "((i == mPair[0] || i == mPair[1]) ? (88 + starts[i]*W) : -20) - ((i == mPair[0] || i == mPair[1]) ? 8 : 0)",
              "28 + i*28 + 7"
            ],
            "fill": "red"
          }
        ]
      }
    ],
    "regions": {
      "repeat": "r5",
      "items": [
        {
          "id": "'row' + i",
          "x": "(i == mPair[0] || i == mPair[1]) ? (88 + starts[i]*W - 11) : (88 + starts[i]*W)",
          "y": "(i == mPair[0] || i == mPair[1]) ? (28 + i*28 - 4) : (28 + i*28)",
          "w": "(i == mPair[0] || i == mPair[1]) ? 22 : dur[i]*W",
          "h": "(i == mPair[0] || i == mPair[1]) ? 22 : 14",
          "correct": "i == target",
          "label": "names[i]",
          "why": "i == target ? (names[i] + ' is the ' + (mode == 1 ? 'later' : 'earlier') + ' milestone — it marks ' + (mode == 1 ? 'completion.' : 'kickoff.')) : ((i == mPair[0] || i == mPair[1]) ? (names[i] + ' is a milestone, but the ' + (mode == 1 ? 'earlier' : 'later') + ' one.') : (names[i] + ' is a task bar with duration, not a milestone.'))"
        }
      ]
    },
    "explanation": "Milestones are zero-duration markers (diamonds). With the tasks running back-to-back, the {{mode == 1 ? 'completion' : 'kickoff'}} milestone is the {{mode == 1 ? 'latest' : 'earliest'}} point on the timeline — here {{names[target]}}."
  },
