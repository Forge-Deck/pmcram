            "anchor": "middle"
          },
          {
            "op": "text",
            "x": "30 + i*60 + 23",
            "y": 184,
            "text": "b[0]",
            "size": 7.5,
            "anchor": "middle"
          }
        ]
      }
    ],
    "regions": {
      "repeat": "bars",
      "as": "b",
      "items": [
        {
          "id": "i",
          "x": "30 + i*60",
          "y": 30,
          "w": 46,
          "h": 138,
          "correct": "mode==1 ? (b[3]==1) : (b[2]==1 && b[1]==maxFailVal)",
          "label": "b[0]",
          "why": "mode==1 ? (b[3]==1 ? 'Prevention — spend here to stop defects before they become costly failures (the COQ leverage point).' : (b[2]==1 ? 'A failure cost — the symptom of too little prevention, not where you invest first.' : 'Appraisal finds defects but does not prevent them.')) : (b[2]==0 ? 'A conformance cost (prevention/appraisal), not a failure cost.' : (b[1]==maxFailVal ? 'A failure (nonconformance) cost, and the larger of the two.' : 'A failure cost, but smaller than the other failure bucket.'))"
        }
      ]
    },
    "explanation": "{{mode==1 ? 'Prevention is the cost-of-quality leverage point — a dollar spent preventing defects saves many in internal and external failure costs.' : 'Nonconformance = failure costs (internal + external). '}}{{mode==1 ? '' : worstName + ' is the larger failure bucket; prevention and appraisal are conformance costs.'}}"
  },
