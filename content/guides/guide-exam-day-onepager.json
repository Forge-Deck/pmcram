[
  {
    "schema": "guide/v1",
    "title": "Exam-Day One-Pager",
    "category": "Exam Strategy",
    "summary": "The final-glance sheet, broken into scan-friendly blocks: a question filter, delivery-model signals, the formula bank, highest-yield mindset rules, must-know acronyms, roles/quality/closure order, people models and procurement/schedule cuts. Read this last, right before you walk in.",
    "sections": [
      {
        "kicker": "Start here",
        "heading": "4-step question filter",
        "body": "Run this before reading the answer options.",
        "blocks": [
          {
            "kind": "steps",
            "items": [
              { "title": "Identify the delivery mode", "lines": ["Sprint, backlog, Product Owner, standup -> agile.", "Baseline, WBS, CCB, earned value -> predictive.", "Tailoring or mixed wording -> hybrid."] },
              { "title": "Separate risk from issue", "lines": ["Already happened -> issue.", "Might happen -> risk."] },
              { "title": "Check decision authority", "lines": ["Agile team decides how the work is done.", "Product Owner prioritises backlog value.", "PM removes blockers and enables the team."] },
              { "title": "Choose the least-drastic correct action", "lines": ["Diagnose first.", "Follow the agreed process.", "Escalate only after the normal path fails."] }
            ]
          },
          {
            "kind": "tip",
            "title": "Exam tip",
            "tone": "bad",
            "lines": ["Don't edit baselines directly.", "Don't escalate before trying the correct process.", "Don't decide for an agile team.", "Don't stay passive when action is required."]
          }
        ]
      },
      {
        "kicker": "Delivery model",
        "heading": "Predictive vs Agile vs Hybrid",
        "body": "Read the wording, then match the answer style.",
        "blocks": [
          {
            "kind": "cards",
            "items": [
              {
                "title": "Predictive",
                "badge": "Waterfall",
                "tone": "accent",
                "groups": [
                  { "label": "Signals", "lines": ["Stable, well-understood scope.", "Baseline, WBS, CCB.", "Critical path, earned value."] },
                  { "label": "Right answer style", "lines": ["Follow the formal process.", "Submit a change request when a baseline changes.", "Protect the approved baseline."] }
                ]
              },
              {
                "title": "Agile",
                "badge": "Adaptive",
                "tone": "good",
                "groups": [
                  { "label": "Signals", "lines": ["Changing requirements.", "Sprint, iteration, user story, backlog.", "Product Owner, standup, self-organising team."] },
                  { "label": "Right answer style", "lines": ["Empower the team.", "Diagnose with the team.", "Let the Product Owner own priority.", "Improve in retrospectives."] }
                ]
              },
              {
                "title": "Hybrid",
                "badge": "Tailored",
                "tone": "warn",
                "groups": [
                  { "label": "Signals", "lines": ["Tailoring is mentioned.", "Predictive and agile terms appear together.", "Some requirements known, some uncertain."] },
                  { "label": "Right answer style", "lines": ["Govern the stable parts.", "Iterate the uncertain parts.", "Break down and prioritise the known requirements."] }
                ]
              }
            ]
          },
          {
            "kind": "tip",
            "title": "Authority check",
            "lines": ["Predictive: the PM plans and directs.", "Agile: the team self-organises.", "Product Owner prioritises value.", "Servant leader removes impediments."]
          }
        ]
      },
      {
        "kicker": "Calculation bank",
        "heading": "Formulae",
        "body": "Each formula sits next to its meaning and exam cue.",
        "blocks": [
          { "kind": "tip", "title": "Interpretation", "tone": "bad", "lines": ["Negative variance is bad.", "Index below 1 is bad."] },
          {
            "kind": "formulas",
            "title": "Earned value",
            "note": "Watch signs",
            "items": [
              { "formula": "CV = EV - AC", "lines": ["Cost variance.", "Negative = over budget."] },
              { "formula": "SV = EV - PV", "lines": ["Schedule variance.", "Negative = behind planned value."] },
              { "formula": "CPI = EV / AC", "lines": ["Cost efficiency.", "Below 1 = poor cost performance."] },
              { "formula": "SPI = EV / PV", "lines": ["Schedule efficiency.", "Below 1 = slower than planned."] },
              { "formula": "EAC = BAC / CPI", "lines": ["Estimate at completion.", "Use when current cost performance continues."] },
              { "formula": "ETC = EAC - AC", "lines": ["Estimate to complete.", "Remaining expected cost from today."] },
              { "formula": "VAC = BAC - EAC", "lines": ["Variance at completion.", "Negative = expected final overrun."] },
              { "formula": "TCPI = (BAC - EV) / (BAC - AC)", "lines": ["Efficiency still needed to hit the budget.", "Use BAC when the target hasn't changed."] }
            ]
          },
          {
            "kind": "formulas",
            "title": "Estimating",
            "items": [
              { "formula": "tE = (O + 4M + P) / 6", "lines": ["PERT three-point estimate.", "Most-likely value weighted by 4."] },
              { "formula": "Std Dev = (P - O) / 6", "lines": ["Estimate spread.", "Optimistic and pessimistic set the range."] }
            ]
          },
          {
            "kind": "formulas",
            "title": "Risk and selection",
            "items": [
              { "formula": "EMV = Probability x Impact", "lines": ["Expected monetary value.", "Sum identified risks to size contingency."] },
              { "formula": "BCR = Benefits / Costs", "lines": ["Above 1 = benefits exceed cost.", "Below 1 = costs exceed benefits."] },
              { "formula": "NPV, IRR, Payback", "lines": ["Higher NPV is better.", "Higher IRR is better.", "Shorter payback is better."] }
            ]
          },
          {
            "kind": "formulas",
            "title": "Schedule and communications",
            "items": [
              { "formula": "Total Float = LS - ES", "lines": ["Also equals LF - EF.", "Critical-path activities have zero total float."] },
              { "formula": "Channels = n(n-1) / 2", "lines": ["n = number of people.", "Paths grow quickly as people are added."] }
            ]
          },
          {
            "kind": "formulas",
            "title": "Procurement",
            "items": [
              { "formula": "PTA = ((Ceiling - Target) / Buyer share) + Target Cost", "lines": ["Point of total assumption.", "Applies to fixed-price incentive-fee contracts."] }
            ]
          },
          {
            "kind": "tip",
            "title": "Formula tip",
            "lines": ["Variance = EV minus (PV or AC).", "Index = EV over (PV or AC).", "EAC = BAC / CPI when performance continues.", "PERT weights the most-likely by 4."]
          }
        ]
      },
      {
        "kicker": "Exam mindset",
        "heading": "Highest-yield rules",
        "body": "Trigger and response split so the answer pattern is easy to scan.",
        "blocks": [
          {
            "kind": "cards",
            "items": [
              { "title": "Baseline change", "groups": [
                { "label": "Trigger", "lines": ["Scope, schedule or cost baseline needs changing."] },
                { "label": "Response", "lines": ["Raise a change request."] },
                { "label": "Caution", "lines": ["Don't edit the baseline directly."] }
              ] },
              { "title": "Issue vs risk", "groups": [
                { "label": "Issue", "lines": ["It has already happened."] },
                { "label": "Risk", "lines": ["It might happen later."] }
              ] },
              { "title": "New risk", "groups": [
                { "label": "Step 1", "lines": ["Record it in the risk register."] },
                { "label": "Step 2", "lines": ["Analyse probability and impact."] },
                { "label": "Step 3", "lines": ["Plan the response and assign a risk owner."] }
              ] },
              { "title": "Known risk fires", "groups": [
                { "label": "Response", "lines": ["Use the planned response."] },
                { "label": "Caution", "lines": ["Don't improvise if a response plan already exists."] }
              ] },
              { "title": "Agile team struggling", "groups": [
                { "label": "Response", "lines": ["Diagnose with the team."] },
                { "label": "Caution", "lines": ["Don't have the PM dictate the fix or just extend the timeline."] }
              ] },
              { "title": "Individual vs whole team", "groups": [
                { "label": "One person", "lines": ["Private one-on-one conversation."] },
                { "label": "Whole team", "lines": ["Bring the team together or survey them.", "Incentives usually backfire."] }
              ] },
              { "title": "Resource removed", "groups": [
                { "label": "Response", "lines": ["Negotiate with the functional manager first."] },
                { "label": "Escalation", "lines": ["Escalate only if negotiation fails."] }
              ] },
              { "title": "Other quick calls", "groups": [
                { "label": "Value uncertain", "lines": ["Build a prototype or MVP."] },
                { "label": "Stakeholder changes", "lines": ["Register = who they are; plan = how to engage."] },
                { "label": "Ground rule broken", "lines": ["Remind directly; strengthen the process only if it recurs."] },
                { "label": "Conflict with emotion", "lines": ["Acknowledge feelings first; never assign blame."] }
              ] }
            ]
          },
          { "kind": "tip", "title": "Mindset tip", "lines": ["Diagnose before treating.", "Follow process before escalating.", "Use the least-drastic correct action."] }
        ]
      },
      {
        "kicker": "Acronyms",
        "heading": "Must-know acronyms",
        "body": "Each acronym on its own row, grouped by area.",
        "blocks": [
          { "kind": "terms", "title": "Agile and product", "items": [
            { "code": "INVEST", "text": "Independent, Negotiable, Valuable, Estimable, Small, Testable." },
            { "code": "MVP", "text": "Minimum Viable Product." },
            { "code": "WIP", "text": "Work In Progress." },
            { "code": "PO", "text": "Product Owner." }
          ] },
          { "kind": "terms", "title": "Planning and responsibility", "items": [
            { "code": "WBS", "text": "Work Breakdown Structure." },
            { "code": "RBS", "text": "Resource Breakdown Structure." },
            { "code": "RTM", "text": "Requirements Traceability Matrix." },
            { "code": "SOW", "text": "Statement of Work." },
            { "code": "RACI", "text": "Responsible, Accountable, Consulted, Informed." },
            { "code": "RAM", "text": "Responsibility Assignment Matrix." }
          ] },
          { "kind": "terms", "title": "Governance and environment", "items": [
            { "code": "CCB", "text": "Change Control Board." },
            { "code": "OPA", "text": "Organisational Process Assets." },
            { "code": "EEF", "text": "Enterprise Environmental Factors." },
            { "code": "PMO", "text": "Project Management Office." },
            { "code": "SME", "text": "Subject Matter Expert." }
          ] },
          { "kind": "terms", "title": "Procurement", "items": [
            { "code": "RFI", "text": "Request for Information." },
            { "code": "RFQ", "text": "Request for Quote." },
            { "code": "RFP", "text": "Request for Proposal." },
            { "code": "FFP", "text": "Firm Fixed Price." },
            { "code": "FPIF", "text": "Fixed Price Incentive Fee." },
            { "code": "FPEPA", "text": "Fixed Price Economic Price Adjustment." },
            { "code": "CPFF", "text": "Cost Plus Fixed Fee." },
            { "code": "CPIF", "text": "Cost Plus Incentive Fee." },
            { "code": "CPAF", "text": "Cost Plus Award Fee." },
            { "code": "T&M", "text": "Time and Material." }
          ] },
          { "kind": "terms", "title": "Performance and value", "items": [
            { "code": "EV", "text": "Earned Value." },
            { "code": "PV", "text": "Planned Value." },
            { "code": "AC", "text": "Actual Cost." },
            { "code": "CV", "text": "Cost Variance." },
            { "code": "SV", "text": "Schedule Variance." },
            { "code": "CPI", "text": "Cost Performance Index." },
            { "code": "SPI", "text": "Schedule Performance Index." },
            { "code": "BAC", "text": "Budget at Completion." },
            { "code": "EAC", "text": "Estimate at Completion." },
            { "code": "EMV", "text": "Expected Monetary Value." },
            { "code": "BCR", "text": "Benefit-Cost Ratio." },
            { "code": "NPV", "text": "Net Present Value." },
            { "code": "IRR", "text": "Internal Rate of Return." },
            { "code": "CoQ", "text": "Cost of Quality." }
          ] },
          { "kind": "terms", "title": "Improvement and change", "items": [
            { "code": "PDCA", "text": "Plan, Do, Check, Act." },
            { "code": "ADKAR", "text": "Awareness, Desire, Knowledge, Ability, Reinforcement." },
            { "code": "OKR", "text": "Objective and Key Results." },
            { "code": "KPI", "text": "Key Performance Indicator." }
          ] },
          { "kind": "tip", "title": "Acronym tip", "text": "When you blank, expand the acronym first - the words usually point to the answer." }
        ]
      },
      {
        "kicker": "Roles and process order",
        "heading": "Roles, quality and closure",
        "body": "Common traps for 'what happens next' questions.",
        "blocks": [
          { "kind": "table", "title": "Who owns what", "rows": [
            { "key": "Sponsor", "value": "Funds and champions one project.\nSigns off acceptance." },
            { "key": "PMO", "value": "Aligns standards across projects.\nMay authorise or terminate." },
            { "key": "PO", "value": "Owns backlog priority and value." },
            { "key": "FM", "value": "Owns the people in a matrix." }
          ] },
          { "kind": "table", "title": "PM authority by structure", "rows": [
            { "key": "Functional", "value": "Little authority." },
            { "key": "Weak matrix", "value": "Coordinator." },
            { "key": "Balanced", "value": "Shared authority." },
            { "key": "Strong matrix", "value": "Moderate to high." },
            { "key": "Projectized", "value": "Full authority." }
          ] },
          { "kind": "steps", "title": "Quality order", "items": [
            { "title": "Plan Quality", "lines": ["Set the standards."] },
            { "title": "Manage Quality", "lines": ["Audits, process, prevention."] },
            { "title": "Control Quality", "lines": ["Inspect deliverables for defects."] },
            { "title": "Validate Scope", "lines": ["Customer formally accepts."] }
          ] },
          { "kind": "table", "title": "Cost of Quality", "rows": [
            { "key": "Conformance", "value": "Prevention + appraisal." },
            { "key": "Nonconform.", "value": "Internal + external failure." }
          ] },
          { "kind": "steps", "title": "Closure order", "items": [
            { "title": "Accept deliverables", "lines": ["Formal acceptance first."] },
            { "title": "Close procurement", "lines": ["Verify work and settle contracts."] },
            { "title": "Lessons learned", "lines": ["Capture before the team disperses."] },
            { "title": "Release the team", "lines": ["Last - and only after finance confirms payment."] }
          ] },
          { "kind": "tip", "title": "Exam tip", "lines": ["Audit = Manage Quality.", "Inspect deliverables = Control Quality.", "Customer sign-off = Validate Scope.", "Sponsor accepts; PMO aligns."] }
        ]
      },
      {
        "kicker": "People topics",
        "heading": "Conflict, leadership and change",
        "body": "The PMP answer usually starts with collaboration, servant leadership and helping people through change.",
        "blocks": [
          { "kind": "steps", "title": "Conflict modes (best first)", "items": [
            { "title": "Collaborate", "lines": ["Problem-solve, win-win. Usually preferred."] },
            { "title": "Compromise", "lines": ["Each side gives something up."] },
            { "title": "Smooth", "lines": ["Emphasise agreement; may not fix the cause."] },
            { "title": "Force", "lines": ["Win-lose; emergencies only."] },
            { "title": "Withdraw", "lines": ["Avoid; usually weak for PMP."] }
          ] },
          { "kind": "steps", "title": "Tuckman", "items": [
            { "title": "Forming" },
            { "title": "Storming" },
            { "title": "Norming" },
            { "title": "Performing" },
            { "title": "Adjourning" }
          ] },
          { "kind": "table", "title": "Leadership", "rows": [
            { "key": "Servant", "value": "Agile default; remove impediments." },
            { "key": "Directive", "value": "Crisis or new/inexperienced team." },
            { "key": "Situational", "value": "Match style to team maturity." },
            { "key": "Transactional", "value": "Rewards for performance." },
            { "key": "Transform.", "value": "Vision and change energy." },
            { "key": "Laissez", "value": "Expert, self-directed team." }
          ] },
          { "kind": "table", "title": "Motivation", "rows": [
            { "key": "Maslow", "value": "Needs hierarchy." },
            { "key": "Herzberg", "value": "Hygiene prevents dissatisfaction; motivators drive it." },
            { "key": "McGregor", "value": "Theory X vs Theory Y." },
            { "key": "McClelland", "value": "Achievement, affiliation, power." },
            { "key": "Vroom", "value": "Effort -> performance -> valued reward." }
          ] },
          { "kind": "table", "title": "Change models", "rows": [
            { "key": "ADKAR", "value": "Individual change." },
            { "key": "Bridges", "value": "Ending -> Neutral Zone -> New Beginning." },
            { "key": "Kubler-Ross", "value": "Emotional change curve." },
            { "key": "Lewin", "value": "Unfreeze, change, refreeze." },
            { "key": "Kotter", "value": "8-step organisation change." },
            { "key": "Satir", "value": "Performance dips then recovers." }
          ] },
          { "kind": "tip", "title": "People tip", "lines": ["Conflict -> collaborate.", "Agile -> servant leadership.", "People lag the system change - plan for the dip."] }
        ]
      },
      {
        "kicker": "Commercial and schedule",
        "heading": "Procurement and schedule quick cuts",
        "body": "High-frequency distinctions, split into decision lines.",
        "blocks": [
          { "kind": "table", "title": "Bid document", "rows": [
            { "key": "RFI", "value": "Gather information." },
            { "key": "RFQ", "value": "Price a well-defined buy." },
            { "key": "RFP", "value": "Complex / unknown solution. Most formal; a new vendor needs it." }
          ] },
          { "kind": "table", "title": "Contract risk", "rows": [
            { "key": "Fixed price", "value": "Seller carries most risk." },
            { "key": "Cost reimb.", "value": "Buyer carries most risk." },
            { "key": "T&M", "value": "Medium; staff aug / small scope." },
            { "key": "FPEPA", "value": "Long deals; inflation or currency." }
          ] },
          { "kind": "steps", "title": "Procurement phases", "items": [
            { "title": "Plan", "lines": ["Make-or-buy decision."] },
            { "title": "Conduct", "lines": ["Issue RFx, select, award."] },
            { "title": "Control", "lines": ["Monitor vendor performance."] },
            { "title": "Close", "lines": ["Verify, pay, close the contract."] }
          ] },
          { "kind": "table", "title": "Schedule compression", "rows": [
            { "key": "Crashing", "value": "Add resources to the critical path; costs money." },
            { "key": "Fast track", "value": "Parallelise sequential work; adds risk." },
            { "key": "Leveling", "value": "Can extend the schedule." },
            { "key": "Smoothing", "value": "Uses float; doesn't extend the schedule." }
          ] },
          { "kind": "tip", "title": "Schedule tip", "lines": ["Critical path = longest path, zero float, drives duration.", "Only critical-path changes shorten the project.", "Never cut planned tests to save time."] }
        ]
      }
    ],
    "tags": ["exam strategy", "cheat sheet", "acronyms", "formulas", "agile", "predictive", "hybrid", "earned value", "quick reference", "exam day"],
    "source": "Compact synthesis of all PM Cram cheat-sheet topics for a final pre-exam review"
  }
]
